{
  "name": "LLM Dual Routing — M1+M2 Sync",
  "nodes": [
    {
      "id": "trigger",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "parameters": {
        "path": "llm-ask",
        "responseMode": "responseNode",
        "httpMethod": "POST"
      }
    },
    {
      "id": "m1-qwen",
      "name": "M1 — Qwen3.5-9B",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [500, 150],
      "parameters": {
        "method": "POST",
        "url": "http://127.0.0.1:1234/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {"parameters": [{"name": "Content-Type","value": "application/json"}]},
        "sendBody": true,
        "contentType": "json",
        "body": "={\"model\":\"qwen/qwen3.5-9b\",\"messages\":[{\"role\":\"system\",\"content\":\"Tu es un assistant concis.\"},{\"role\":\"user\",\"content\":\"{{ $json.prompt }}\"}],\"max_tokens\":3000,\"temperature\":0.2}",
        "options": {"timeout": 120000}
      }
    },
    {
      "id": "m1-r1",
      "name": "M1 — DeepSeek-R1",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
